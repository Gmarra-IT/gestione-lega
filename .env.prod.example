# Copia su VM come /opt/gestione-lega/.env (NON versionare i valori reali).
# DB dedicato nell'istanza Postgres esistente. Host=postgres = nome container sulla rete condivisa.
DB_CONNECTION=Host=postgres;Port=5432;Database=classifica_lega;Username=classifica_lega;Password=CAMBIAMI

# Nome della rete Docker esterna dove gira il container postgres (docker network ls).
POSTGRES_NETWORK=postgres_default

# Chiave firma JWT (>= 32 char, random). Genera: openssl rand -base64 48
JWT_KEY=CAMBIAMI-chiave-random-lunga

# Admin login. Hash BCrypt della password (NON la password in chiaro).
# Genera hash: vedi docs/deploy.md
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$replace-with-real-bcrypt-hash
